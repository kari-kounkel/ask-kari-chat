{
  "routes": [
    { "src": "/askkari", "dest": "/askkari.html" },
    { "src": "/widget.js", "dest": "/widget.js" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
